# NPM Configuration
# See: https://docs.npmjs.com/configuring-npm/npmrc

# Strict mode: fail on missing imports
strict-peer-dependencies=false

# Always verify peer dependencies
verify-store-integrity=true

# Use integrity checks
check-version=true

# Prune unused dependencies
audit-level=moderate

# Save exact versions (not ranges)
# Uncomment to enforce exact versions
# save-exact=true

# Prefer offline mode for CI/CD
# offline=true (only set in CI)

# Use git over https for public packages
# git-protocol=https

# Ensure we're publishing the right scope (if using @org/package)
# Uncomment if using an organization scope:
# @org:registry=https://registry.npmjs.org/

# Allow running scripts from dependencies
scripts-prepend-node-path=true

# Timeout for network requests (ms)
fetch-timeout=120000

# Allow writing to ~/.npm for cache
# cache=/home/user/.npm

# Publishing
# Set this only when pushing to npm
# (Do NOT commit auth token)
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Audit settings
# Ignore very minor/non-critical vulnerabilities in dev dependencies
# audit-level=moderate will ignore low severity

# Optional: Set loglevel for CI/CD
# loglevel=verbose (for debugging CI issues)
